# ── HEAVY / jorasite — environment ───────────────────────────
# Copy to .env (on the server: /opt/jorasite/.env) and fill in.
# .env is git-ignored and must never be committed. chmod 600.

# Network: backend binds to loopback only; Nginx is the public entry point.
HOST=127.0.0.1
PORT=3000
NODE_ENV=production

# ── Meta Conversions API ─────────────────────────────────────
# Pixel ID (dataset ID), same value used in index.html.
META_PIXEL_ID=000000000000000

# CAPI access token (Events Manager → Settings → Conversions API).
# SECRET — keep out of git and the browser.
META_CAPI_TOKEN=YOUR_LONG_CAPI_ACCESS_TOKEN

# Optional: test event code while verifying in the Test Events tab.
# Leave blank/commented in production.
# META_TEST_EVENT_CODE=

# ── Monobank acquiring (Plata by mono) ───────────────────────
# Acquiring token from Monobank merchant cabinet / api.monobank.ua.
# SECRET — server-side only, never in the browser, never in git.
MONOBANK_TOKEN=YOUR_MONOBANK_ACQUIRING_TOKEN

# Public origin used to build Monobank redirect + webhook URLs.
# Must be reachable from the internet (Monobank calls the webhook).
PUBLIC_BASE_URL=https://jorasite.girafi.keenetic.name

# Optional: override the charge amount while TESTING (kopiykas; 10000 = 100 UAH).
# Leave unset in production — the real price comes from the TICKETS catalog.
# MONOBANK_TEST_AMOUNT=10000

# ── Ticketing (JWT / ES256) ──────────────────────────────────
# QR tickets are JWTs signed with an EC keypair. PRIVATE key signs (server-only),
# PUBLIC key verifies at the door. Generate the keypair once:
#   openssl ecparam -genkey -name prime256v1 | openssl pkcs8 -topk8 -nocrypt -out ticket_ec_private.pem
#   openssl ec -in ticket_ec_private.pem -pubout -out ticket_ec_public.pem
# Point these at the PEM files (multi-line PEM doesn't fit EnvironmentFile):
TICKET_PRIVATE_KEY_FILE=/opt/jorasite/keys/ticket_ec_private.pem
TICKET_PUBLIC_KEY_FILE=/opt/jorasite/keys/ticket_ec_public.pem
# Alternatively inline a single-line PEM with literal \n:  TICKET_PRIVATE_KEY="-----BEGIN...\n...\n-----END..."
# Ticket validity (jsonwebtoken expiresIn). Default 180d.
# TICKET_TTL=180d

# Writable dir for the JSON order/ticket store (granted by the systemd unit).
# DATA_DIR=/opt/jorasite/data

# ── Email (SMTP) for sending QR tickets ──────────────────────
# Without these, tickets are still generated + stored, but no email is sent.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="HEAVY <tickets@yourdomain>"
