# HEAVY / he4vy.com (cPanel/LiteSpeed) — route extensionless API paths to the
# PHP proxies, so the frontend can keep calling /api/photos etc. unchanged
# (those routes are native on the Node/LXC host; here they map to PHP).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^api/photos/?$    /api/photos.php   [L,QSA]
  RewriteRule ^api/download/?$  /api/download.php [L,QSA]
  RewriteRule ^api/photo/?$     /api/download.php?inline=1 [L,QSA]

  # YouTube video feed (cached RSS proxy)
  RewriteRule ^api/youtube/?$          /api/youtube.php          [L,QSA]

  # Event info for the checkout modal
  RewriteRule ^api/event/?$            /api/event.php            [L,QSA]

  # Monobank acquiring (PHP backend)
  RewriteRule ^api/create-invoice/?$   /api/create-invoice.php   [L,QSA]
  RewriteRule ^api/check-status/?$     /api/check-status.php     [L,QSA]
  RewriteRule ^api/monobank-webhook/?$ /api/monobank-webhook.php [L,QSA]

  # Door ticket verification (POST /use marks used; GET checks)
  RewriteRule ^api/verify-ticket/use/?$ /api/verify-ticket.php   [L,QSA]
  RewriteRule ^api/verify-ticket/?$     /api/verify-ticket.php   [L,QSA]

  # SPA tab routes → index.html (JS reads path and opens the tab)
  RewriteRule ^tickets/?$              /index.html                [L,QSA]
  RewriteRule ^photos/?$               /index.html                [L,QSA]
  RewriteRule ^booking/?$              /index.html                [L,QSA]

  # Pretty paths
  RewriteRule ^payment-result/?$       /payment-result.html      [L,QSA]
  RewriteRule ^verify/?$               /verify.html              [L,QSA]
</IfModule>

# Belt-and-suspenders: if a monobank_config.php ever lands in the web root, deny it.
<FilesMatch "^monobank_config.*\.php$">
  Require all denied
</FilesMatch>
